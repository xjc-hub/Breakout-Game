cmake_minimum_required(VERSION 3.10)
project(Breakout)

set(CMAKE_CXX_STANDARD 17)

# 1. 设置Raylib路径（关键修改）
# 假设您的raylib-5.0目录结构与Windows预编译版本一致
set(RAYLIB_ROOT "${CMAKE_SOURCE_DIR}/raylib-5.0")
include_directories(${RAYLIB_ROOT}/include)  # Windows版本头文件通常在include目录
link_directories(${RAYLIB_ROOT}/lib)         # Windows库文件通常在lib目录

# 2. 添加可执行文件（源文件部分保持不变）
add_executable(breakout_week2 
    src/main.cpp 
    src/Ball.cpp 
    src/Paddle.cpp 
    src/Brick.cpp
)

# 3. 链接库（关键修改：移除Linux库，添加Windows系统库）
if(WIN32)
    # Windows平台链接
    target_link_libraries(breakout_week2 
        raylib           # 链接raylib库
        opengl32         # OpenGL库（Windows）
        gdi32            # 图形设备接口库
        winmm            # Windows多媒体库
        # 移除了Linux特有的 m, pthread, dl, rt, X11
    )
else()
    # 保留原有的Linux链接方式作为备选
    target_link_libraries(breakout_week2 raylib m pthread dl rt X11)
endif()
